{
  "name": "vietnam-province-intelligence-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "build": "tsc -p tsconfig.json && cp -r src/data/realProvinceFeatures.json dist/data/ && cp -r src/data/province_in4 dist/data/ && cp -r src/data/pdf dist/data/ && cp src/data/tinhThanhVnProvinceReference.json dist/data/",
    "start": "node --env-file .env dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@turf/turf": "^7.2.0",
    "cors": "^2.8.5",
    "duck-duck-scrape": "^2.2.7",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
